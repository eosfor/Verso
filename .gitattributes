# Default: treat as text, normalize to LF in the repo
* text=auto eol=lf

# Source files
*.cs       text eol=lf
*.razor    text eol=lf
*.cshtml   text eol=lf
*.csproj   text eol=lf
*.props    text eol=lf
*.targets  text eol=lf
*.sln      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.html     text eol=lf
*.sh       text eol=lf
*.ps1      text eol=lf
*.fs       text eol=lf
*.fsproj   text eol=lf
*.py       text eol=lf
*.verso    text eol=lf
*.dib      text eol=lf
*.ipynb    text eol=lf

# Windows-only scripts that must stay CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf

# Binaries
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      text eol=lf
*.dll      binary
*.exe      binary
*.pdb      binary
*.snk      binary
*.zip      binary
*.gz       binary
*.tar      binary
*.woff     binary
*.woff2    binary
*.ttf      binary
*.otf      binary
*.eot      binary
*.pdf      binary
