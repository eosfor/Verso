@using System.Net
@using System.Text
@using System.Text.Json
@using Verso.Blazor.Shared.Models
@inject INotebookService Service
@inject IJSRuntime JS

<div class="verso-cell @(IsSelected ? "verso-cell--selected" : "") @(IsExecuting ? "verso-cell--executing" : "") @(IsInPreviewMode ? "verso-cell--preview" : "")">
    <div class="verso-cell-gutter">
        <div class="verso-cell-gutter-actions">
            @if (IsEditable)
            {
                @if (IsExecuting && CanStopExecution)
                {
                    <button class="verso-cell-btn verso-cell-btn--stop verso-cell-gutter-btn"
                            @onclick="() => OnCancelCell.InvokeAsync(CellData.Id)"
                            title="Stop">
                        <span>&#x25A0;</span>
                    </button>
                }
                else
                {
                    <button class="verso-cell-btn verso-cell-btn--run verso-cell-gutter-btn"
                            @onclick="() => OnRunCell.InvokeAsync(CellData.Id)"
                            title="Run" disabled="@IsExecuting">
                        @if (IsExecuting) { <span class="verso-spinner"></span> } else { <span>&#x25B6;</span> }
                    </button>
                }
            }
            @if (IsHeadingCell)
            {
                <button class="verso-cell-btn verso-cell-gutter-btn verso-cell-gutter-btn--collapse"
                        @onclick="() => OnToggleSection.InvokeAsync(CellData.Id)"
                        title="@(IsSectionCollapsed ? "Expand Section" : "Collapse Section")">
                    <span class="verso-cell-collapse-chevron @(IsSectionCollapsed ? "verso-cell-collapse-chevron--collapsed" : "")">&#x25BC;</span>
                </button>
            }
            @if (SupportsInputCollapse)
            {
                <button class="verso-cell-btn verso-cell-gutter-btn verso-cell-gutter-btn--collapse"
                        @onclick="ToggleInputCollapseAsync"
                        title="@(IsInputCollapsed ? "Expand Code" : "Collapse Code")">
                    <span class="verso-cell-collapse-chevron @(IsInputCollapsed ? "verso-cell-collapse-chevron--collapsed" : "")">&#x25BC;</span>
                </button>
            }
        </div>
        <span class="verso-cell-index">[@(Index + 1)]</span>
    </div>

    <div class="verso-cell-content">
        <div class="verso-cell-toolbar">
            <div class="verso-cell-type-dropdown" @onfocusout="OnTypeDropdownFocusOut" tabindex="-1">
                <button class="verso-cell-type-badge" @onclick="ToggleTypeDropdown">
                    @CellData.Type
                    <span class="verso-cell-type-chevron">&#9662;</span>
                </button>
                @if (_showTypeDropdown)
                {
                    <div class="verso-cell-type-popup">
                        @foreach (var ct in Service.AvailableCellTypes)
                        {
                            var t = ct;
                            var isActive = string.Equals(t.Id, CellData.Type, StringComparison.OrdinalIgnoreCase);
                            <button class="verso-cell-type-option @(isActive ? "verso-cell-type-option--active" : "")"
                                    @onclick="() => SelectCellType(t.Id)">
                                @t.DisplayName
                            </button>
                        }
                    </div>
                }
            </div>
            @if (CellData.Type == "code" && CellData.Language is not null)
            {
                <div class="verso-cell-lang-dropdown" @onfocusout="OnLanguageDropdownFocusOut" tabindex="-1">
                    <button class="verso-cell-lang-badge" @onclick="ToggleLanguageDropdown">
                        @GetLanguageDisplayName(CellData.Language)
                        <span class="verso-cell-lang-chevron">&#9662;</span>
                    </button>
                    @if (_showLanguageDropdown)
                    {
                        <div class="verso-cell-lang-popup">
                            @foreach (var lang in Service.RegisteredLanguages)
                            {
                                var l = lang;
                                var isActive = string.Equals(l.Id, CellData.Language, StringComparison.OrdinalIgnoreCase);
                                <button class="verso-cell-lang-option @(isActive ? "verso-cell-lang-option--active" : "")"
                                        @onclick="() => SelectLanguage(l.Id)">
                                    @l.DisplayName
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            <div class="verso-cell-toolbar-actions">
                @foreach (var action in _enabledCellActions)
                {
                    var act = action;
                    <button class="verso-cell-btn verso-cell-btn--action"
                            @onclick="() => ExecuteCellActionAsync(act)"
                            title="Export @act.DisplayName">
                        @if (act.Icon is not null)
                        {
                            @((MarkupString)act.Icon)
                        }
                        else
                        {
                            @act.DisplayName
                        }
                    </button>
                }
                @if (Index > 0)
                {
                    <button class="verso-cell-btn" @onclick="() => OnMoveUp.InvokeAsync(CellData.Id)" title="Move Up">&#x25B2;</button>
                }
                @if (!IsLast)
                {
                    <button class="verso-cell-btn" @onclick="() => OnMoveDown.InvokeAsync(CellData.Id)" title="Move Down">&#x25BC;</button>
                }
                <button class="verso-cell-btn verso-cell-btn--delete" @onclick="() => OnDeleteCell.InvokeAsync(CellData.Id)" title="Delete">&#x2715;</button>
            </div>
        </div>

        @if (!IsEditable)
        {
            @* Non-editable cell types (e.g. parameters): show rendered output directly, no editor *@
            @if (IsOutputHidden)
            {
                <div class="verso-cell-output-summary" @onclick="() => OnSelect.InvokeAsync(CellData.Id)">
                    @OutputSummaryText
                </div>
            }
            else if (CellData.Outputs.Count > 0)
            {
                <div class="verso-cell-rendered-input @(IsOutputPreview ? "verso-cell-rendered-input--preview" : "")"
                     style="@OutputPreviewStyle"
                     data-cell-id="@CellData.Id"
                     @onclick="() => OnSelect.InvokeAsync(CellData.Id)">
                    @foreach (var output in CellData.Outputs)
                    {
                        @if (output.IsError)
                        {
                            <div class="verso-output verso-output--error">
                                <div class="verso-output-error-name">@(output.ErrorName ?? "Error")</div>
                                <pre class="verso-output-error-content">@output.Content</pre>
                            </div>
                        }
                        else if (output.MimeType == "text/html" || output.MimeType == "image/svg+xml")
                        {
                            @* @key forces Blazor to tear down and recreate the element when the
                               output object changes, rather than diffing MarkupString child nodes
                               in place which can cause removeChild errors when interactive
                               elements (inputs, checkboxes) hold browser-managed DOM state. *@
                            <div @key="output" class="verso-output verso-output--html">
                                @((MarkupString)output.Content)
                            </div>
                        }
                        else
                        {
                            <div class="verso-output verso-output--text">
                                <pre>@output.Content</pre>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <div class="verso-cell-rendered-input verso-cell-rendered-input--loading"
                     @onclick="() => OnSelect.InvokeAsync(CellData.Id)">
                    <span class="verso-spinner"></span>
                </div>
            }
        }
        else if (SupportsInputCollapse && IsInputCollapsed)
        {
            <div class="verso-cell-source-preview" @onclick="() => OnSelect.InvokeAsync(CellData.Id)">
                <pre>@CollapsedSourcePreview</pre>
            </div>
        }
        else if (!IsInPreviewMode)
        {
            <div class="verso-cell-editor" @onclick="() => OnSelect.InvokeAsync(CellData.Id)">
                <MonacoEditor Value="@CellData.Source"
                              Language="@EditorLanguage"
                              OnValueChanged="HandleSourceChanged"
                              OnEditorAction="HandleEditorAction"
                              OnGetHoverInfo="HandleGetHoverInfo"
                              OnGetCompletions="HandleGetCompletions" />
            </div>
        }

        @if (CellData.ExecutionCount is not null && !IsInPreviewMode && IsEditable)
        {
            <div class="verso-cell-status verso-cell-status--@EffectiveStatus">
                <span class="verso-cell-status-icon">@StatusIcon</span>
                <span class="verso-cell-status-elapsed">@FormatElapsed(CellData.LastElapsed)</span>
                <span class="verso-cell-status-count">[@CellData.ExecutionCount]</span>
            </div>
        }

        @if (CellData.Outputs.Count > 0 && IsEditable)
        {
            @if (IsOutputHidden)
            {
                <div class="verso-cell-output-summary" @onclick="HandleOutputClick">
                    @OutputSummaryText
                </div>
            }
            else
            {
                <div class="verso-cell-outputs @(IsInPreviewMode ? "verso-cell-outputs--clickable" : "") @(IsOutputPreview ? "verso-cell-outputs--preview" : "")"
                     style="@OutputPreviewStyle"
                     data-cell-id="@CellData.Id"
                     @onclick="HandleOutputClick">
                    @foreach (var output in CellData.Outputs)
                    {
                        @if (output.IsError)
                        {
                            <div class="verso-output verso-output--error">
                                <div class="verso-output-error-name">@(output.ErrorName ?? "Error")</div>
                                <pre class="verso-output-error-content">@output.Content</pre>
                                @if (output.ErrorStackTrace is not null)
                                {
                                    <pre class="verso-output-error-stack">@output.ErrorStackTrace</pre>
                                }
                            </div>
                        }
                        else if (output.MimeType == "text/x-verso-mermaid")
                        {
                            <div class="verso-output verso-output--html verso-mermaid-container">
                                <pre class="mermaid">@output.Content</pre>
                            </div>
                        }
                        else if (output.MimeType == "text/html" || output.MimeType == "image/svg+xml")
                        {
                            <div class="verso-output verso-output--html">
                                @((MarkupString)output.Content)
                            </div>
                        }
                        else if (output.MimeType.StartsWith("image/"))
                        {
                            <div class="verso-output verso-output--html">
                                <img src="@($"data:{output.MimeType};base64,{output.Content}")" style="max-width:100%" />
                            </div>
                        }
                        else if (output.MimeType == "application/json")
                        {
                            <div class="verso-output verso-output--html">
                                @((MarkupString)RenderJsonTree(output.Content))
                            </div>
                        }
                        else if (output.MimeType == "text/csv")
                        {
                            <div class="verso-output verso-output--html">
                                @((MarkupString)RenderCsvTable(output.Content))
                            </div>
                        }
                        else
                        {
                            <div class="verso-output verso-output--text">
                                <pre>@output.Content</pre>
                            </div>
                        }
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter] public CellModel CellData { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsExecuting { get; set; }
    [Parameter] public int Index { get; set; }
    [Parameter] public bool IsLast { get; set; }
    [Parameter] public EventCallback<Guid> OnRunCell { get; set; }
    [Parameter] public EventCallback<Guid> OnCancelCell { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteCell { get; set; }
    [Parameter] public EventCallback<Guid> OnSelect { get; set; }
    [Parameter] public EventCallback<Guid> OnMoveUp { get; set; }
    [Parameter] public EventCallback<Guid> OnMoveDown { get; set; }
    [Parameter] public EventCallback<(Guid CellId, string Source)> OnSourceChanged { get; set; }
    [Parameter] public EventCallback<(Guid CellId, string Action)> OnCellAction { get; set; }
    [Parameter] public EventCallback<(Guid CellId, string NewType)> OnCellTypeChanged { get; set; }
    [Parameter] public EventCallback<(Guid CellId, string NewLanguage)> OnCellLanguageChanged { get; set; }
    [Parameter] public bool CollapsesInput { get; set; }
    [Parameter] public bool IsEditable { get; set; } = true;
    [Parameter] public bool IsHeadingCell { get; set; }
    [Parameter] public bool IsSectionCollapsed { get; set; }
    [Parameter] public EventCallback<Guid> OnToggleSection { get; set; }

    private List<ToolbarActionInfo> _enabledCellActions = new();
    private bool _showTypeDropdown;
    private bool _showLanguageDropdown;

    // Actions already represented by hardcoded buttons in the cell toolbar
    private static readonly HashSet<string> _hardcodedActionIds = new(StringComparer.OrdinalIgnoreCase)
    {
        "verso.action.run-cell"
    };

    private bool _hasMermaidContent;
    private bool _pendingAutoExecute;

    private bool SupportsInputCollapse => IsEditable && string.Equals(CellData.Type, "code", StringComparison.OrdinalIgnoreCase);

    private bool IsInputCollapsed => ReadMetadataBool(CellViewStateMetadata.InputCollapsedKey);

    private string OutputVisibilityMode => NormalizeOutputVisibility(ReadMetadataString(CellViewStateMetadata.OutputVisibilityKey));

    private bool IsOutputPreview => string.Equals(OutputVisibilityMode, CellViewStateMetadata.OutputPreview, StringComparison.Ordinal);

    private bool IsOutputHidden => string.Equals(OutputVisibilityMode, CellViewStateMetadata.OutputHidden, StringComparison.Ordinal);

    private int InputPreviewLineCount => ReadMetadataInt(
        CellViewStateMetadata.InputPreviewLineCountKey,
        CellViewStateMetadata.DefaultInputPreviewLineCount);

    private int OutputPreviewLineCount => ReadMetadataInt(
        CellViewStateMetadata.OutputPreviewLineCountKey,
        CellViewStateMetadata.DefaultOutputPreviewLineCount);

    private string OutputPreviewStyle => IsOutputPreview
        ? $"--verso-output-preview-lines: {OutputPreviewLineCount};"
        : "";

    private string OutputSummaryText => $"{CellData.Outputs.Count} output(s) hidden";

    private string CollapsedSourcePreview => BuildCollapsedSourcePreview(CellData.Source, InputPreviewLineCount);

    private bool IsInPreviewMode => CollapsesInput && CellData.Outputs.Count > 0 && !IsSelected
        && !string.IsNullOrWhiteSpace(CellData.Source);

    private string EditorLanguage => CellData.Type == "markdown" ? "markdown" : (CellData.Language ?? "csharp");

    private bool HasErrorOutput => CellData.Outputs.Any(o => o.IsError);

    private bool CanStopExecution => CellData.Language is not null
        && (Service.RegisteredLanguages
            .FirstOrDefault(l => string.Equals(l.Id, CellData.Language, StringComparison.OrdinalIgnoreCase))
            ?.SupportsCancellation ?? false);

    private string EffectiveStatus => HasErrorOutput
        ? "failed"
        : (CellData.LastStatus?.ToLowerInvariant()) switch
        {
            null or "success" or "completed" => "success",
            var s => s
        };

    private string StatusIcon => EffectiveStatus switch
    {
        "success" => "\u2714",    // ✔
        "failed" => "\u2718",     // ✘
        "cancelled" => "\u2014",  // —
        _ => "\u2714"
    };

    private static string FormatElapsed(TimeSpan? elapsed)
    {
        if (elapsed is not { } ts) return "";
        return ts.TotalSeconds < 60
            ? $"{ts.TotalSeconds:F1}s"
            : $"{ts.TotalMinutes:F1}m";
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!Service.IsLoaded)
        {
            _enabledCellActions = new();
            return;
        }

        var cellActions = Service.GetToolbarActions(ToolbarPlacement.CellToolbar)
            .Where(a => !_hardcodedActionIds.Contains(a.ActionId))
            .ToList();

        if (cellActions.Count == 0)
        {
            _enabledCellActions = new();
            return;
        }

        var enabledStates = await Service.GetActionEnabledStatesAsync(
            ToolbarPlacement.CellToolbar,
            new List<Guid> { CellData.Id });

        _enabledCellActions = cellActions
            .Where(a => enabledStates.GetValueOrDefault(a.ActionId, false)
                        && !_hardcodedActionIds.Contains(a.ActionId))
            .ToList();

        _hasMermaidContent = CellData.Outputs.Any(o => o.MimeType == "text/x-verso-mermaid");

        // Schedule auto-execute for non-editable cells that have no outputs yet
        if (!IsEditable && CellData.Outputs.Count == 0 && !IsExecuting)
            _pendingAutoExecute = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_pendingAutoExecute)
        {
            _pendingAutoExecute = false;
            await OnRunCell.InvokeAsync(CellData.Id);
        }

        if (_hasMermaidContent)
        {
            try { await JS.InvokeVoidAsync("versoMermaid.renderAll"); }
            catch (JSException) { }
        }
    }

    private async Task ExecuteCellActionAsync(ToolbarActionInfo action)
    {
        await Service.ExecuteActionAsync(action.ActionId, new List<Guid> { CellData.Id });
    }

    private async Task HandleEditorAction(string action)
    {
        await OnCellAction.InvokeAsync((CellData.Id, action));
    }

    private async Task HandleSourceChanged(string newSource)
    {
        await OnSourceChanged.InvokeAsync((CellData.Id, newSource));
    }

    private async Task HandleOutputClick()
    {
        if (IsInPreviewMode)
        {
            await OnSelect.InvokeAsync(CellData.Id);
        }
    }

    private async Task ToggleInputCollapseAsync()
    {
        await Service.NotifyPropertyChangedAsync(
            CellData.Id,
            CellViewStateMetadata.ProviderExtensionId,
            CellViewStateMetadata.InputCollapsedProperty,
            !IsInputCollapsed);
    }

    private async Task<object?> HandleGetHoverInfo(string code, int position)
    {
        var info = await Service.GetHoverInfoAsync(CellData.Id, code, position);
        if (info is null) return null;

        if (info.Range is { } r)
            return new { content = info.Content, range = new { startLine = r.StartLine, startColumn = r.StartColumn, endLine = r.EndLine, endColumn = r.EndColumn } };

        return new { content = info.Content };
    }

    private async Task<object?> HandleGetCompletions(string code, int position)
    {
        var completions = await Service.GetCompletionsAsync(CellData.Id, code, position);
        if (completions is null) return null;

        return new
        {
            items = completions.Items.Select(c => new
            {
                displayText = c.DisplayText,
                insertText = c.InsertText,
                kind = c.Kind,
                description = c.Description,
                sortText = c.SortText
            }).ToArray()
        };
    }

    private void ToggleTypeDropdown()
    {
        _showTypeDropdown = !_showTypeDropdown;
        if (_showTypeDropdown) _showLanguageDropdown = false;
    }

    private async Task OnTypeDropdownFocusOut()
    {
        await Task.Delay(150);
        _showTypeDropdown = false;
    }

    private async Task SelectCellType(string typeId)
    {
        _showTypeDropdown = false;
        if (!string.Equals(typeId, CellData.Type, StringComparison.OrdinalIgnoreCase))
            await OnCellTypeChanged.InvokeAsync((CellData.Id, typeId));
    }

    private void ToggleLanguageDropdown()
    {
        _showLanguageDropdown = !_showLanguageDropdown;
        if (_showLanguageDropdown) _showTypeDropdown = false;
    }

    private async Task OnLanguageDropdownFocusOut()
    {
        await Task.Delay(150);
        _showLanguageDropdown = false;
    }

    private async Task SelectLanguage(string languageId)
    {
        _showLanguageDropdown = false;
        if (!string.Equals(languageId, CellData.Language, StringComparison.OrdinalIgnoreCase))
            await OnCellLanguageChanged.InvokeAsync((CellData.Id, languageId));
    }

    private string GetLanguageDisplayName(string languageId)
    {
        var info = Service.RegisteredLanguages
            .FirstOrDefault(l => string.Equals(l.Id, languageId, StringComparison.OrdinalIgnoreCase));
        return info?.DisplayName ?? languageId;
    }

    private bool ReadMetadataBool(string key)
    {
        if (!CellData.Metadata.TryGetValue(key, out var value) || value is null)
            return false;

        return value switch
        {
            bool b => b,
            JsonElement { ValueKind: JsonValueKind.True } => true,
            JsonElement { ValueKind: JsonValueKind.False } => false,
            string s when bool.TryParse(s, out var parsed) => parsed,
            _ => false
        };
    }

    private string? ReadMetadataString(string key)
    {
        if (!CellData.Metadata.TryGetValue(key, out var value) || value is null)
            return null;

        return value switch
        {
            string s => s,
            JsonElement { ValueKind: JsonValueKind.String } element => element.GetString(),
            _ => value.ToString()
        };
    }

    private int ReadMetadataInt(string key, int defaultValue)
    {
        if (!CellData.Metadata.TryGetValue(key, out var value) || value is null)
            return defaultValue;

        var parsed = value switch
        {
            int i => i,
            long l when l <= int.MaxValue && l >= int.MinValue => (int)l,
            double d when d <= int.MaxValue && d >= int.MinValue => (int)d,
            JsonElement { ValueKind: JsonValueKind.Number } element when element.TryGetInt32(out var i) => i,
            string s when int.TryParse(s, out var i) => i,
            _ => defaultValue
        };

        return parsed > 0 ? parsed : defaultValue;
    }

    private static string NormalizeOutputVisibility(string? visibility)
    {
        if (string.Equals(visibility, CellViewStateMetadata.OutputPreview, StringComparison.OrdinalIgnoreCase))
            return CellViewStateMetadata.OutputPreview;
        if (string.Equals(visibility, CellViewStateMetadata.OutputHidden, StringComparison.OrdinalIgnoreCase))
            return CellViewStateMetadata.OutputHidden;
        return CellViewStateMetadata.OutputExpanded;
    }

    private static string BuildCollapsedSourcePreview(string source, int lineCount)
    {
        var lines = source
            .Replace("\r\n", "\n", StringComparison.Ordinal)
            .Split('\n')
            .Select(static line => line.TrimEnd())
            .Where(static line => !string.IsNullOrWhiteSpace(line))
            .ToList();

        if (lines.Count == 0)
            return "(empty)";

        var previewLines = lines.Take(Math.Max(1, lineCount)).ToList();
        if (lines.Count > previewLines.Count)
            previewLines.Add("...");

        return string.Join(Environment.NewLine, previewLines);
    }

    // --- MIME type renderers ---

    private static string RenderCsvTable(string content)
    {
        var sb = new StringBuilder();
        sb.Append("<style>");
        sb.Append(".verso-csv{border-collapse:collapse;width:100%;font-family:var(--verso-code-output-font-family,monospace);font-size:13px;");
        sb.Append("background:var(--vscode-editor-background,var(--verso-cell-output-background,#fff));");
        sb.Append("color:var(--vscode-editor-foreground,var(--verso-cell-output-foreground,#1e1e1e))}");
        sb.Append(".verso-csv th{padding:6px 12px;text-align:left;white-space:nowrap;");
        sb.Append("background:var(--vscode-editorWidget-background,var(--verso-cell-background,#f5f5f5));");
        sb.Append("border:1px solid var(--vscode-editorWidget-border,var(--verso-border-default,#e0e0e0));font-weight:600}");
        sb.Append(".verso-csv td{padding:4px 12px;");
        sb.Append("background:var(--vscode-editor-background,var(--verso-cell-output-background,#fff));");
        sb.Append("border:1px solid var(--vscode-editorWidget-border,var(--verso-border-default,#e0e0e0));white-space:nowrap}");
        sb.Append(".verso-csv tr:hover td{background:var(--vscode-list-hoverBackground,var(--verso-cell-hover-background,#f0f0f0))}");
        sb.Append("</style>");

        var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        if (lines.Length == 0) return "<span>Empty CSV</span>";

        sb.Append("<div style='max-height:400px;overflow:auto;border:1px solid var(--vscode-editorWidget-border,#e0e0e0);border-radius:4px'>");
        sb.Append("<table class='verso-csv'>");

        for (int i = 0; i < lines.Length; i++)
        {
            var cells = ParseCsvLine(lines[i]);
            var tag = i == 0 ? "th" : "td";
            sb.Append("<tr>");
            foreach (var cell in cells)
                sb.Append($"<{tag}>{WebUtility.HtmlEncode(cell)}</{tag}>");
            sb.Append("</tr>");
        }

        sb.Append("</table></div>");
        return sb.ToString();
    }

    private static List<string> ParseCsvLine(string line)
    {
        var fields = new List<string>();
        var current = new StringBuilder();
        bool inQuotes = false;

        for (int i = 0; i < line.Length; i++)
        {
            var c = line[i];
            if (inQuotes)
            {
                if (c == '"' && i + 1 < line.Length && line[i + 1] == '"')
                {
                    current.Append('"');
                    i++;
                }
                else if (c == '"')
                {
                    inQuotes = false;
                }
                else
                {
                    current.Append(c);
                }
            }
            else if (c == '"')
            {
                inQuotes = true;
            }
            else if (c == ',')
            {
                fields.Add(current.ToString().Trim());
                current.Clear();
            }
            else
            {
                current.Append(c);
            }
        }

        fields.Add(current.ToString().Trim());
        return fields;
    }

    private static string RenderJsonTree(string content)
    {
        try
        {
            using var doc = JsonDocument.Parse(content);
            var sb = new StringBuilder();
            sb.Append("<style>");
            sb.Append(".verso-json{font-family:var(--verso-code-output-font-family,monospace);font-size:13px;");
            sb.Append("color:var(--vscode-editor-foreground,#1e1e1e);line-height:1.5}");
            sb.Append(".verso-json details{margin-left:16px}");
            sb.Append(".verso-json summary{cursor:pointer;list-style:none;user-select:none}");
            sb.Append(".verso-json summary::-webkit-details-marker{display:none}");
            sb.Append(".verso-json summary::before{content:'\\25B6';font-size:9px;margin-right:4px;");
            sb.Append("color:var(--vscode-descriptionForeground,#858585);display:inline-block;transition:transform 0.1s}");
            sb.Append(".verso-json details[open]>summary::before{transform:rotate(90deg)}");
            sb.Append(".verso-json .jk{color:var(--vscode-textLink-foreground,#0078d4)}");
            sb.Append(".verso-json .js{color:var(--vscode-debugTokenExpression-string,#a31515)}");
            sb.Append(".verso-json .jn{color:var(--vscode-debugTokenExpression-number,#098658)}");
            sb.Append(".verso-json .jb{color:var(--vscode-debugTokenExpression-boolean,#0000ff)}");
            sb.Append(".verso-json .jnull{color:var(--vscode-descriptionForeground,var(--verso-editor-line-number,#858585));font-style:italic}");
            sb.Append(".verso-json .jbrace{color:var(--vscode-editor-foreground,var(--verso-cell-output-foreground,#1e1e1e))}");
            sb.Append(".verso-json .jcount{color:var(--vscode-editor-foreground,var(--verso-cell-output-foreground,#1e1e1e));opacity:0.7}");
            sb.Append("</style>");
            sb.Append("<div class='verso-json'>");
            RenderJsonElement(sb, doc.RootElement, null, 0);
            sb.Append("</div>");
            return sb.ToString();
        }
        catch
        {
            return $"<pre>{WebUtility.HtmlEncode(content)}</pre>";
        }
    }

    private static void RenderJsonElement(StringBuilder sb, JsonElement element, string? key, int depth)
    {
        var keyHtml = key is not null ? $"<span class='jk'>\"{WebUtility.HtmlEncode(key)}\"</span>: " : "";

        switch (element.ValueKind)
        {
            case JsonValueKind.Object:
                var objProps = element.EnumerateObject().ToList();
                if (objProps.Count == 0)
                {
                    sb.Append($"<div>{keyHtml}<span class='jbrace'>{{}}</span></div>");
                }
                else
                {
                    sb.Append($"<details{(depth < 2 ? " open" : "")}>");
                    sb.Append($"<summary>{keyHtml}<span class='jbrace'>{{</span> <span class='jcount'>{objProps.Count} {(objProps.Count == 1 ? "key" : "keys")}</span></summary>");
                    foreach (var prop in objProps)
                        RenderJsonElement(sb, prop.Value, prop.Name, depth + 1);
                    sb.Append($"<div><span class='jbrace'>}}</span></div></details>");
                }
                break;

            case JsonValueKind.Array:
                var items = element.EnumerateArray().ToList();
                if (items.Count == 0)
                {
                    sb.Append($"<div>{keyHtml}<span class='jbrace'>[]</span></div>");
                }
                else
                {
                    sb.Append($"<details{(depth < 2 ? " open" : "")}>");
                    sb.Append($"<summary>{keyHtml}<span class='jbrace'>[</span> <span class='jcount'>{items.Count} {(items.Count == 1 ? "item" : "items")}</span></summary>");
                    foreach (var item in items)
                        RenderJsonElement(sb, item, null, depth + 1);
                    sb.Append($"<div><span class='jbrace'>]</span></div></details>");
                }
                break;

            case JsonValueKind.String:
                sb.Append($"<div>{keyHtml}<span class='js'>\"{WebUtility.HtmlEncode(element.GetString())}\"</span></div>");
                break;

            case JsonValueKind.Number:
                sb.Append($"<div>{keyHtml}<span class='jn'>{element.GetRawText()}</span></div>");
                break;

            case JsonValueKind.True:
            case JsonValueKind.False:
                sb.Append($"<div>{keyHtml}<span class='jb'>{element.GetRawText()}</span></div>");
                break;

            case JsonValueKind.Null:
                sb.Append($"<div>{keyHtml}<span class='jnull'>null</span></div>");
                break;
        }
    }
}
