@page "/"
@implements IDisposable
@using Verso.Abstractions
@using Verso.Blazor.Wasm.Services
@inject INotebookService Service
@inject VsCodeBridge Bridge
@inject IJSRuntime JS

@* VS Code webview theme is driven by --vscode-* CSS variables mapped in the webview HTML *@

<div class="verso-notebook"
     tabindex="0" @onkeydown="HandleKeyDown">
    <Toolbar Service="Service"
             SelectedCellId="_selectedCellId"
             OnSaveNotebook="HandleSave"
             OnAddCell="HandleAddCell"
             OnActionExecuted="HandleActionExecuted"
             OnInterceptAction="HandleInterceptAction"
             OnError="HandleError" />

    @if (_showExtensionConsent && _pendingConsentExtensions is not null)
    {
        <ExtensionConsentDialog IsVisible="true"
                                Extensions="_pendingConsentExtensions"
                                OnConsentResult="HandleExtensionConsentResult" />
    }

    @if (_error is not null)
    {
        <div class="verso-error-banner">
            <span>@_error</span>
            <button @onclick="() => _error = null">Dismiss</button>
        </div>
    }

    @if (_statusMessage is not null)
    {
        <div class="verso-status-banner">
            <span>@_statusMessage</span>
        </div>
    }

    @if (!Service.IsLoaded)
    {
        <div class="verso-welcome">
            <div style="display:flex;align-items:center;gap:8px;">
                <div class="verso-spinner"></div>
                <span>Waiting for notebook content...</span>
            </div>
        </div>
    }
    else
    {
        <div class="verso-notebook-body">
            <div class="verso-notebook-main">
                @if (Service.ActiveLayoutId == "dashboard")
                {
                    <DashboardGrid Service="Service"
                                   Cells="GetLayoutFilteredCells()"
                                   ExecutingCellId="_executingCellId"
                                   OnRunCell="HandleRunCell"
                                   OnSourceChanged="HandleSourceChanged" />
                }
                else if (Service.ActiveLayoutId == "presentation")
                {
                    <PresentationView Service="Service"
                                      Cells="GetLayoutFilteredCells()" />
                }
                else
                {
                    <div class="verso-cell-list" @onclick="HandleCellListClick">
                        @{
                            var cells = Service.Cells;
                            var cellTypes = Service.AvailableCellTypes;
                        }
                        @{
                            int? skipUntilLevel = null;
                        }
                        @for (int i = 0; i < cells.Count; i++)
                        {
                            var cell = cells[i];
                            var index = i;
                            var headingLevel = HeadingDetector.GetHeadingLevel(cell);

                            if (skipUntilLevel is not null)
                            {
                                if (headingLevel is not null && headingLevel.Value <= skipUntilLevel.Value)
                                {
                                    skipUntilLevel = null;
                                }
                                else
                                {
                                    continue;
                                }
                            }

                            var isSectionCollapsed = _collapsedSections.Contains(cell.Id);

                            <div @onclick:stopPropagation="true" data-cell-index="@index">
                                <Cell CellData="cell"
                                      IsSelected="cell.Id == _selectedCellId"
                                      IsExecuting="cell.Id == _executingCellId"
                                      Index="index"
                                      IsLast="index == cells.Count - 1"
                                      CollapsesInput="Service.ShouldCollapseInput(cell.Type)"
                                      IsEditable="Service.IsCellTypeEditable(cell.Type)"
                                      IsHeadingCell="headingLevel is not null"
                                      IsSectionCollapsed="isSectionCollapsed"
                                      OnToggleSection="HandleToggleSection"
                                      OnRunCell="HandleRunCell"
                                      OnDeleteCell="HandleDeleteCell"
                                      OnSelect="HandleSelectCell"
                                      OnMoveUp="HandleMoveUp"
                                      OnMoveDown="HandleMoveDown"
                                      OnSourceChanged="HandleSourceChanged"
                                      OnCellAction="HandleCellAction"
                                      OnCellTypeChanged="HandleCellTypeChanged"
                                      OnCellLanguageChanged="HandleCellLanguageChanged" />
                            </div>

                            @if (headingLevel is not null && isSectionCollapsed)
                            {
                                skipUntilLevel = headingLevel;
                            }

                            @if (index < cells.Count - 1)
                            {
                                var insertIndex = index + 1;
                                <div class="verso-insert-cell-row @(cell.Id == _selectedCellId ? "verso-insert-cell-row--visible" : "")">
                                    <div class="verso-insert-cell-line"></div>
                                    @foreach (var ct in cellTypes)
                                    {
                                        var idx = insertIndex;
                                        var typeId = ct.Id;
                                        <button class="verso-insert-cell-btn" @onclick="() => HandleInsertCell(idx, typeId)">+ @ct.DisplayName</button>
                                    }
                                    <div class="verso-insert-cell-line"></div>
                                </div>
                            }
                        }

                        @if (Service.LayoutCapabilities.HasFlag(LayoutCapabilities.CellInsert))
                        {
                            <div class="verso-add-cell-row">
                                @foreach (var ct in cellTypes)
                                {
                                    var typeId = ct.Id;
                                    <button class="verso-add-cell-btn" @onclick="() => HandleAddCell(typeId)">+ @ct.DisplayName Cell</button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="verso-panel-container">
                @if (_activePanel is not null)
                {
                    <div class="verso-panel-content" @ref="_panelContentEl" style="width:@(_panelWidth)px">
                        <div class="verso-panel-resize-handle" @ref="_resizeHandle"></div>
                        <div class="verso-panel-header">
                            <span class="verso-panel-title">@PanelDisplayName(_activePanel)</span>
                            <button class="verso-panel-minimize" @onclick="CollapsePanel" title="Collapse panel">&#x203A;</button>
                        </div>
                        <div class="verso-panel-body">
                            @if (_activePanel == "metadata")
                            {
                                <MetadataPanel Service="Service" />
                            }
                            else if (_activePanel == "extensions")
                            {
                                <ExtensionPanel Service="Service" />
                            }
                            else if (_activePanel == "variables")
                            {
                                <VariableExplorer Service="Service" />
                            }
                            else if (_activePanel == "settings")
                            {
                                <SettingsPanel Service="Service" />
                            }
                            else if (_activePanel == "properties")
                            {
                                <CellPropertiesPanel Service="Service" SelectedCellId="_selectedCellId" />
                            }
                        </div>
                    </div>
                }

                <div class="verso-panel-strip">
                    <button class="verso-panel-strip-tab @(_activePanel == "metadata" ? "verso-panel-strip-tab--active" : "")"
                            @onclick='() => TogglePanel("metadata")' title="Metadata">
                        <svg class="verso-panel-strip-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="1.5" width="10" height="13" rx="1"/>
                            <line x1="5.5" y1="5" x2="10.5" y2="5"/>
                            <line x1="5.5" y1="7.5" x2="10.5" y2="7.5"/>
                            <line x1="5.5" y1="10" x2="8.5" y2="10"/>
                        </svg>
                        <span>Metadata</span>
                    </button>
                    <button class="verso-panel-strip-tab @(_activePanel == "extensions" ? "verso-panel-strip-tab--active" : "")"
                            @onclick='() => TogglePanel("extensions")' title="Extensions">
                        <svg class="verso-panel-strip-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6.5 2.5h3v3h3v3h-3v3h-3v-3h-3v-3h3z"/>
                        </svg>
                        <span>Extensions</span>
                    </button>
                    <button class="verso-panel-strip-tab @(_activePanel == "variables" ? "verso-panel-strip-tab--active" : "")"
                            @onclick='() => TogglePanel("variables")' title="Variables">
                        <svg class="verso-panel-strip-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4.5 2.5c-1.5 0-2 1-2 2s1 1.5 1 2.5-.5 1-1 1.5c.5.5 1 .5 1 1.5s-1 1.5-1 2.5.5 2 2 2"/>
                            <path d="M11.5 2.5c1.5 0 2 1 2 2s-1 1.5-1 2.5.5 1 1 1.5c-.5.5-1 .5-1 1.5s1 1.5 1 2.5-.5 2-2 2"/>
                            <line x1="6.5" y1="6" x2="9.5" y2="10"/>
                            <line x1="6.5" y1="10" x2="9.5" y2="6"/>
                        </svg>
                        <span>Variables</span>
                    </button>
                    <button class="verso-panel-strip-tab @(_activePanel == "settings" ? "verso-panel-strip-tab--active" : "")"
                            @onclick='() => TogglePanel("settings")' title="Settings">
                        <svg class="verso-panel-strip-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="8" cy="8" r="2.5"/>
                            <path d="M8 1.5v2M8 12.5v2M1.5 8h2M12.5 8h2M3.1 3.1l1.4 1.4M11.5 11.5l1.4 1.4M3.1 12.9l1.4-1.4M11.5 4.5l1.4-1.4"/>
                        </svg>
                        <span>Settings</span>
                    </button>
                    @if (Service.ActiveLayoutSupportsPropertiesPanel)
                    {
                        <button class="verso-panel-strip-tab @(_activePanel == "properties" ? "verso-panel-strip-tab--active" : "")"
                                @onclick='() => TogglePanel("properties")' title="Properties">
                            <svg class="verso-panel-strip-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="2" y="2" width="12" height="12" rx="1.5"/>
                                <line x1="5" y1="5.5" x2="11" y2="5.5"/>
                                <line x1="5" y1="8" x2="9" y2="8"/>
                                <line x1="5" y1="10.5" x2="10" y2="10.5"/>
                            </svg>
                            <span>Properties</span>
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private Guid? _selectedCellId;
    private Guid? _executingCellId;
    private HashSet<Guid> _collapsedSections = new();
    private string? _error;
    private string? _statusMessage;
    private CancellationTokenSource? _statusCts;
    private string? _activePanel;
    private int _panelWidth = 300;
    private DotNetObjectReference<NotebookPage>? _panelResizeRef;
    private DotNetObjectReference<NotebookPage>? _cellDragRef;
    private ElementReference _resizeHandle;
    private ElementReference _panelContentEl;
    private bool _panelResizeInitialized;
    private bool _showExtensionConsent;
    private IReadOnlyList<ExtensionConsentInfo>? _pendingConsentExtensions;
    private bool _userPrefsApplied;
    private bool _restoringPrefs;

    private string _monacoThemeName = "vs";

    private async Task<string> DetectMonacoThemeAsync()
    {
        try
        {
            var kind = await JS.InvokeAsync<string>("vscodeBridge.getThemeKind");
            return kind == "dark" ? "vs-dark" : "vs";
        }
        catch { return "vs"; }
    }

    protected override void OnInitialized()
    {
        Service.OnCellExecuted += HandleCellExecutedRefresh;
        Service.OnCellExecuting += HandleCellExecutingEvent;
        Service.OnCellExecutionCompleted += HandleCellExecutedEvent;
        Service.OnNotebookChanged += HandleNotebookChanged;
        Service.OnLayoutChanged += HandleLayoutChanged;
        Service.OnThemeChanged += HandleThemeChanged;
        Service.OnExtensionStatusChanged += HandleExtensionStatusChanged;
        Service.OnVariablesChanged += HandleVariablesChanged;
        Service.OnSettingsChanged += HandleSettingsChanged;
        Service.OnOutputUpdated += HandleOutputUpdated;

        if (Service is RemoteNotebookService remoteService)
        {
            remoteService.OnExtensionConsentRequested += HandleExtensionConsentRequested;
            remoteService.OnKernelRestarting += HandleKernelRestarting;
            remoteService.OnKernelRestarted += HandleKernelRestarted;
            remoteService.OnLayoutMissing += HandleLayoutMissing;
        }
    }

    private void HandleKernelRestarting(string? kernelId)
    {
        _ = InvokeAsync(async () =>
        {
            // Persistent banner — cleared explicitly by HandleKernelRestarted rather
            // than the 3-second timeout used by ShowStatusAsync.
            _statusCts?.Cancel();
            _statusMessage = "Restarting kernel...";
            StateHasChanged();
            await Task.CompletedTask;
        });
    }

    private void HandleKernelRestarted(string? kernelId)
    {
        _ = InvokeAsync(async () =>
        {
            _executingCellId = null;

            var hasExtensionCells = Service.Cells.Any(c =>
                c.Source is not null &&
                (c.Source.Contains("#!nuget", StringComparison.Ordinal)
                 || c.Source.Contains("#!extension", StringComparison.Ordinal)
                 || c.Source.Contains("#r \"nuget:", StringComparison.Ordinal)));

            var message = hasExtensionCells
                ? "Kernel restarted. Re-run cells with #!nuget or #!extension to reload."
                : "Kernel restarted";

            await ShowStatusAsync(message);
        });
    }

    private void HandleLayoutMissing(string layoutId)
    {
        _ = InvokeAsync(async () =>
        {
            await ShowStatusAsync(
                $"Layout '{layoutId}' not loaded. Run the cell containing #!extension or #!nuget to load it.");
        });
    }

    private void HandleCellExecutedRefresh()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleCellExecutingEvent(Guid cellId)
    {
        // The JSON-RPC bridge notification dispatch is not guaranteed to run
        // on the renderer's dispatcher. Marshal before mutating component state.
        _ = InvokeAsync(() =>
        {
            _executingCellId = cellId;
            StateHasChanged();
        });
    }

    private void HandleCellExecutedEvent(Guid cellId)
    {
        _ = InvokeAsync(() =>
        {
            if (_executingCellId == cellId)
                _executingCellId = null;
            StateHasChanged();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Wait for Monaco to fully load before processing notebook
            // notifications.  This ensures define.amd is removed before any
            // cell outputs (which may contain AMD-interfering scripts) render.
            await JS.InvokeVoidAsync("versoMonaco.waitForReady");

            // Subscribe BEFORE initializing so replayed notifications are caught
            Bridge.OnNotification += HandleBridgeNotification;

            // Initialize the bridge notification handler (may replay queued notifications)
            await Bridge.InitializeAsync();

            // If the notification was already processed, re-render immediately
            if (Service.IsLoaded)
            {
                StateHasChanged();
            }

            _cellDragRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("versoCellDrag.init", _cellDragRef);


            await SyncMonacoThemeAsync();

            await ApplyUserPreferencesAsync();
        }

        if (_activePanel is not null && !_panelResizeInitialized)
        {
            _panelResizeInitialized = true;
            _panelResizeRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("versoPanel.initResize", _resizeHandle, _panelContentEl, _panelResizeRef, 200, 600);
            }
            catch (JSException) { }
        }
        else if (_activePanel is null)
        {
            _panelResizeInitialized = false;
        }
    }

    private async void HandleBridgeNotification(string method, string? paramsJson)
    {
        if (method == "notebook/opened")
        {
            // The extension opened the file and sent its content through
            // The RemoteNotebookService handles this internally
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void HandleNotebookChanged()
    {
        // Apply user preferences once extension data is available.
        // The service fires OnNotebookChanged after RefreshExtensionDataAsync,
        // so themes/extensions are populated by this point.
        await InvokeAsync(async () =>
        {
            await ApplyUserPreferencesAsync();
            StateHasChanged();
        });
    }

    private async void HandleLayoutChanged()
    {
        // Collapse properties panel if the new layout doesn't support it
        if (_activePanel == "properties" && !Service.ActiveLayoutSupportsPropertiesPanel)
            _activePanel = null;

        if (Service.ActiveLayoutId == "presentation")
        {
            await InvokeAsync(async () =>
            {
                await HandleRunAll();
                StateHasChanged();
            });
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void HandleThemeChanged()
    {
        // Theme is driven by VS Code — no localStorage persistence needed
        await SyncMonacoThemeAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleExtensionStatusChanged()
    {
        if (!_restoringPrefs)
        {
            try
            {
                var disabledIds = Service.Extensions
                    .Where(e => e.Status == ExtensionStatus.Disabled)
                    .Select(e => e.ExtensionId)
                    .ToArray();
                await JS.InvokeVoidAsync("versoUserPrefs.setDisabledExtensions", (object)disabledIds);
            }
            catch (JSException) { }
        }
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleVariablesChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleSettingsChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async void HandleExtensionConsentRequested()
    {
        if (Service is RemoteNotebookService remoteService)
        {
            _pendingConsentExtensions = remoteService.PendingConsentExtensions;
            _showExtensionConsent = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleExtensionConsentResult(bool approved)
    {
        _showExtensionConsent = false;
        _pendingConsentExtensions = null;

        if (Service is RemoteNotebookService remoteService)
            await remoteService.ResolveConsentResultAsync(approved);
    }

    private async void HandleOutputUpdated()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task SyncMonacoThemeAsync()
    {
        try
        {
            _monacoThemeName = await DetectMonacoThemeAsync();
            await JS.InvokeVoidAsync("versoMonaco.setTheme", _monacoThemeName);
        }
        catch (JSException) { }
    }

    private async Task ApplyUserPreferencesAsync()
    {
        if (_userPrefsApplied) return;

        // Extensions aren't available until a notebook is loaded
        if (!Service.IsLoaded || Service.Extensions.Count == 0) return;

        _restoringPrefs = true;
        try
        {
            var allExtIds = Service.Extensions.Select(e => e.ExtensionId).ToHashSet();

            var disabledIds = await JS.InvokeAsync<string[]?>("versoUserPrefs.getDisabledExtensions");
            if (disabledIds is not null)
            {
                foreach (var id in disabledIds)
                {
                    if (allExtIds.Contains(id))
                        await Service.DisableExtensionAsync(id);
                }

                // Scrub stale IDs that no longer match any loaded extension
                var cleaned = disabledIds.Where(allExtIds.Contains).ToArray();
                if (cleaned.Length != disabledIds.Length)
                    await JS.InvokeVoidAsync("versoUserPrefs.setDisabledExtensions", (object)cleaned);
            }

            // Theme is driven by VS Code in webview mode — no Verso theme persistence needed

            _userPrefsApplied = true;
        }
        catch (JSException) { }
        finally
        {
            _restoringPrefs = false;
        }
    }

    private IReadOnlyList<CellModel> GetLayoutFilteredCells()
    {
        return Service.Cells
            .Where(c => Service.ResolveCellVisibility(c.Id) != CellVisibilityState.Hidden)
            .ToList();
    }

    private void TogglePanel(string panelId)
    {
        if (_activePanel == panelId)
            _activePanel = null;
        else
            _activePanel = panelId;
    }

    private void CollapsePanel()
    {
        _activePanel = null;
    }

    private static string PanelDisplayName(string panelId) => panelId switch
    {
        "metadata" => "METADATA",
        "extensions" => "EXTENSIONS",
        "variables" => "VARIABLES",
        "settings" => "SETTINGS",
        "properties" => "PROPERTIES",
        _ => panelId.ToUpperInvariant()
    };

    [JSInvokable]
    public void OnPanelResized(int width)
    {
        _panelWidth = width;
        InvokeAsync(StateHasChanged);
    }

    private async Task HandleSave()
    {
        try
        {
            _error = null;
            await Service.SaveAsync(Service.FilePath ?? "notebook.verso");
            await ShowStatusAsync("Saved");
        }
        catch (Exception ex)
        {
            _error = $"Failed to save: {ex.Message}";
        }
    }

    private async Task ShowStatusAsync(string message)
    {
        _statusCts?.Cancel();
        _statusCts = new CancellationTokenSource();
        var token = _statusCts.Token;

        _statusMessage = message;
        StateHasChanged();

        try
        {
            await Task.Delay(3000, token);
            _statusMessage = null;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private async Task HandleInsertCell(int index, string type)
    {
        var cell = await Service.InsertCellAsync(index, type);
        _selectedCellId = cell.Id;
    }

    private async Task HandleAddCell(string type)
    {
        var cell = await Service.AddCellAsync(type);
        _selectedCellId = cell.Id;
    }

    private async Task HandleRunCell(Guid cellId)
    {
        // _executingCellId and cell metadata are managed by HandleCellExecutingEvent /
        // HandleCellExecutedEvent (driven by the host's cell/executionState notifications
        // and Scaffold.OnCellExecuting/OnCellExecuted on the engine side).
        try
        {
            await Service.ExecuteCellAsync(cellId);
        }
        catch (Exception ex)
        {
            _error = $"Execution error: {ex.Message}";
        }
    }

    private async Task HandleDeleteCell(Guid cellId)
    {
        await Service.RemoveCellAsync(cellId);
        if (_selectedCellId == cellId)
            _selectedCellId = Service.Cells.FirstOrDefault()?.Id;
    }

    private Task HandleSelectCell(Guid cellId)
    {
        _selectedCellId = cellId;
        return Task.CompletedTask;
    }

    private void HandleToggleSection(Guid cellId)
    {
        if (!_collapsedSections.Remove(cellId))
            _collapsedSections.Add(cellId);
    }

    private async Task HandleCellAction((Guid CellId, string Action) args)
    {
        var (cellId, action) = args;
        switch (action)
        {
            case "run-and-stay":
                await HandleRunCell(cellId);
                break;
            case "run-and-select-below":
                await HandleRunCell(cellId);
                await SelectNextCell(cellId, addIfLast: true);
                await ScrollToSelectedCell();
                break;
            case "run-and-insert-below":
                await HandleRunCell(cellId);
                await InsertAndSelectBelow(cellId);
                await ScrollToSelectedCell();
                break;
            case "escape":
                _selectedCellId = cellId;
                break;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && e.CtrlKey && e.AltKey)
        {
            await HandleRunAll();
            return;
        }

        if (e.Key == "Escape")
        {
            _selectedCellId = null;
            return;
        }

        if (_selectedCellId is not { } selectedId) return;

        switch (e.Key)
        {
            case "ArrowUp" when e.AltKey:
                await HandleMoveUp(selectedId);
                break;
            case "ArrowDown" when e.AltKey:
                await HandleMoveDown(selectedId);
                break;
            case "ArrowUp":
                SelectPreviousCell(selectedId);
                await ScrollToSelectedCell();
                break;
            case "ArrowDown":
                await SelectNextCell(selectedId);
                await ScrollToSelectedCell();
                break;
            case "Enter" when e.ShiftKey:
                await HandleRunCell(selectedId);
                await SelectNextCell(selectedId, addIfLast: true);
                await ScrollToSelectedCell();
                break;
            case "Enter" when e.CtrlKey:
                await HandleRunCell(selectedId);
                break;
            case "Enter" when e.AltKey:
                await HandleRunCell(selectedId);
                await InsertAndSelectBelow(selectedId);
                await ScrollToSelectedCell();
                break;
            case "Enter":
                await FocusSelectedEditor();
                break;
        }
    }

    private async Task HandleRunAll()
    {
        // Per-cell UI updates flow via HandleCellExecutingEvent / HandleCellExecutedEvent,
        // driven by the host's cell/executionState notifications that the RemoteNotebookService
        // decodes. A trailing RefreshCellListAsync inside ExecuteAllAsync re-hydrates cell
        // metadata (ExecutionCount / LastElapsed / LastStatus) from the host.
        try
        {
            await Service.ExecuteAllAsync();
        }
        catch (Exception ex)
        {
            _error = $"Execution error: {ex.Message}";
        }
    }

    private async Task SelectNextCell(Guid currentId, bool addIfLast = false)
    {
        var cells = Service.Cells;
        var cellList = cells.ToList();
        var index = cellList.FindIndex(c => c.Id == currentId);
        if (index < 0) return;

        if (index < cellList.Count - 1)
        {
            _selectedCellId = cellList[index + 1].Id;
        }
        else if (addIfLast)
        {
            var newCell = await Service.AddCellAsync("code");
            _selectedCellId = newCell.Id;
        }
    }

    private void SelectPreviousCell(Guid currentId)
    {
        var cells = Service.Cells;
        var cellList = cells.ToList();
        var index = cellList.FindIndex(c => c.Id == currentId);
        if (index > 0)
            _selectedCellId = cellList[index - 1].Id;
    }

    private async Task InsertAndSelectBelow(Guid currentId)
    {
        var cells = Service.Cells;
        var cellList = cells.ToList();
        var index = cellList.FindIndex(c => c.Id == currentId);
        if (index < 0) return;

        var newCell = await Service.InsertCellAsync(index + 1, "code");
        _selectedCellId = newCell.Id;
    }

    private async Task ScrollToSelectedCell()
    {
        if (_selectedCellId is null) return;
        StateHasChanged();
        await Task.Yield();
        try
        {
            await JS.InvokeVoidAsync("versoMonaco.scrollToSelected");
        }
        catch (JSException) { }
    }

    private async Task FocusSelectedEditor()
    {
        if (_selectedCellId is null) return;
        try
        {
            await JS.InvokeVoidAsync("versoMonaco.focusByContainer",
                $".verso-cell--selected .verso-cell-editor");
        }
        catch (JSException) { }
    }

    private void HandleCellListClick()
    {
        _selectedCellId = null;
    }

    private async Task HandleMoveUp(Guid cellId)
    {
        var cells = Service.Cells;
        var index = cells.ToList().FindIndex(c => c.Id == cellId);
        if (index > 0) await Service.MoveCellAsync(index, index - 1);
    }

    private async Task HandleMoveDown(Guid cellId)
    {
        var cells = Service.Cells;
        var cellList = cells.ToList();
        var index = cellList.FindIndex(c => c.Id == cellId);
        if (index >= 0 && index < cellList.Count - 1) await Service.MoveCellAsync(index, index + 1);
    }

    [JSInvokable]
    public async Task OnCellDragDrop(int fromIndex, int insertBeforeIndex)
    {
        var count = Service.Cells.Count;
        if (fromIndex < 0 || fromIndex >= count) return;

        int toIndex;
        if (insertBeforeIndex >= count)
            toIndex = count - 1;
        else if (insertBeforeIndex > fromIndex)
            toIndex = insertBeforeIndex - 1;
        else
            toIndex = insertBeforeIndex;

        toIndex = Math.Clamp(toIndex, 0, count - 1);
        if (toIndex != fromIndex)
            await Service.MoveCellAsync(fromIndex, toIndex);
    }

    private async Task HandleSourceChanged((Guid CellId, string Source) args)
    {
        await Service.UpdateCellSourceAsync(args.CellId, args.Source);
    }

    private async Task HandleCellTypeChanged((Guid CellId, string NewType) args)
    {
        await Service.ChangeCellTypeAsync(args.CellId, args.NewType);
    }

    private async Task HandleCellLanguageChanged((Guid CellId, string NewLanguage) args)
    {
        await Service.ChangeCellLanguageAsync(args.CellId, args.NewLanguage);
    }

    private async Task<bool> HandleInterceptAction(string actionId)
    {
        if (string.Equals(actionId, "verso.action.run-all", StringComparison.OrdinalIgnoreCase))
        {
            await HandleRunAll();
            return true;
        }

        if (string.Equals(actionId, "verso.action.run-cell", StringComparison.OrdinalIgnoreCase)
            && _selectedCellId.HasValue)
        {
            await HandleRunCell(_selectedCellId.Value);
            return true;
        }

        return false;
    }

    private Task HandleActionExecuted(string actionId)
    {
        if (string.Equals(actionId, "verso.action.run-all", StringComparison.OrdinalIgnoreCase))
            _selectedCellId = null;

        // Restart Kernel feedback is now driven by the kernel/restarting and
        // kernel/restarted notifications from the supervisor, since the actual
        // restart happens out-of-process via host kill+respawn.

        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleError(string message)
    {
        _error = message;
        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _statusCts?.Cancel();
        _statusCts?.Dispose();
        _panelResizeRef?.Dispose();
        _cellDragRef?.Dispose();
        Bridge.OnNotification -= HandleBridgeNotification;
        Service.OnCellExecuted -= HandleCellExecutedRefresh;
        Service.OnCellExecuting -= HandleCellExecutingEvent;
        Service.OnCellExecutionCompleted -= HandleCellExecutedEvent;
        Service.OnNotebookChanged -= HandleNotebookChanged;
        Service.OnLayoutChanged -= HandleLayoutChanged;
        Service.OnThemeChanged -= HandleThemeChanged;
        Service.OnExtensionStatusChanged -= HandleExtensionStatusChanged;
        Service.OnVariablesChanged -= HandleVariablesChanged;
        Service.OnSettingsChanged -= HandleSettingsChanged;
        Service.OnOutputUpdated -= HandleOutputUpdated;

        if (Service is RemoteNotebookService remoteService)
        {
            remoteService.OnExtensionConsentRequested -= HandleExtensionConsentRequested;
            remoteService.OnKernelRestarting -= HandleKernelRestarting;
            remoteService.OnKernelRestarted -= HandleKernelRestarted;
            remoteService.OnLayoutMissing -= HandleLayoutMissing;
        }
    }
}
